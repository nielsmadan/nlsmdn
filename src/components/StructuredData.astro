---
export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || "Niels Madan",
      url: "https://nlsmdn.com/about",
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Person",
      name: "Niels Madan",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || "https://nlsmdn.com/og.png",
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Niels Madan",
    url: "https://nlsmdn.com",
    sameAs: [
      "https://github.com/nielsmadan",
      "https://www.linkedin.com/in/nielsmadan/",
    ],
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "nlsmdn",
    url: "https://nlsmdn.com",
    author: {
      "@type": "Person",
      name: "Niels Madan",
    },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://nlsmdn.com/search?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
