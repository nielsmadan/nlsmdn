---
type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/search?q=${tag}`}
    transition:name={tag}
    class:list={[
      "inline-flex items-baseline",
      "hover:text-accent",
      "focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-base": size === "lg" },
    ]}
  >
    <span class="mr-0.5 text-[0.75em] opacity-60">#</span>{tagName}
  </a>
</li>
